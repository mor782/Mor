const test = require('node:test');
const assert = require('node:assert');


const { countLetters, countArr, arrNum, hasNull } = require('./utils');

test('ceck letter count in word', (t) => {
    const result = countLetters('Shecode', 'e');
    assert.strictEqual(result, 2);
});

test('check that empty array length is zero', (t) => {
    const emptyArray = [];
    const result = arrNum(emptyArray);
    assert.strictEqual(result, 0);
})


test('should return true if array contains null', (t) => {
    const testArray = [1, 2, null, 4, 5]; // מערך דמה קצר
    const result = hasNull(testArray);
    
    assert.strictEqual(result, true);
});

test('should find null in a generated range', (t) => {
    const testArray = []; // המערך המלא שלך
    const result = hasNull(testArray);
    
    assert.strictEqual(result, false);
});